{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.TsvetanG2/cognigy-ai-mcp-management-server",
  "description": "MCP server for managing Cognigy.AI virtual agents - create flows, train NLU, deploy snapshots, and more via natural language",
  "repository": {
    "url": "https://github.com/TsvetanG2/cognigy-ai-mcp-management-server",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "cognigy-ai-mcp-management-server",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "COGNIGY_BASE_URL",
          "description": "Cognigy API base URL (e.g., https://api-trial.cognigy.ai)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "COGNIGY_API_KEY",
          "description": "Your Cognigy API key (from My Profile → API Keys)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
