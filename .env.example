# Cognigy.AI MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Your Cognigy API base URL
# Trial: https://api-trial.cognigy.ai
# SaaS EU: https://api-app.cognigy.ai
# SaaS US: https://api-app-us.cognigy.ai
# Other SaaS: https://api-<company>.cognigy.cloud
COGNIGY_BASE_URL=https://api-trial.cognigy.ai

# Required: Your Cognigy API key
# Generate at: My Profile → API Keys in the Cognigy UI
COGNIGY_API_KEY=your-api-key-here

# Optional: Default project ID for operations
# COGNIGY_DEFAULT_PROJECT_ID=
